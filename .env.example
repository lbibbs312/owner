# Copy this file to .env and fill in real values. Never commit .env.
# All values shown here are placeholders / safe defaults for local dev.

# Flask session signing key. MUST be a long random string in any non-dev
# environment. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# SQLAlchemy connection string. Defaults to a local SQLite file if unset.
# For Postgres (recommended for staging/prod):
#   SQLALCHEMY_DATABASE_URI=postgresql+psycopg://user:pass@localhost:5432/movedefense_customer
SQLALCHEMY_DATABASE_URI=sqlite:///movedefense_customer.db

# Set to "true" to enable Flask/Werkzeug debugger. NEVER true in production
# (the debugger exposes a remote code execution console).
FLASK_DEBUG=false

# Set to "true" when serving over HTTPS so session cookies are only sent
# over secure connections. Leave "false" for local HTTP development.
SESSION_COOKIE_SECURE=false

# Public production URLs. Keep database and secret settings separate from
# domain/front-door changes. REDIRECT_HOSTS is optional. Leave it empty for customer services unless
# you are intentionally preserving an old domain that should redirect to CANONICAL_HOST.
APP_URL=https://movedefense-customer.onrender.com
BASE_URL=https://movedefense-customer.onrender.com
PUBLIC_URL=https://movedefense-customer.onrender.com
CANONICAL_HOST=movedefense-customer.onrender.com
REDIRECT_HOSTS=

# Shared secret required to self-register as a manager via /register.
# Leave unset to disable manager self-registration entirely (recommended
# once SSO group-based role assignment is in place).
MANAGER_REGISTRATION_PIN=

# Printable docs can be downloaded as local email attachments from the browser.
